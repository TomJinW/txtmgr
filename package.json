{
  "name": "txtmgr",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:build:exe": "tauri build --no-bundle",
    "tauri:build:exe:win-x64": "tauri build --no-bundle --target x86_64-pc-windows-msvc",
    "tauri:build:exe:win-arm64": "tauri build --no-bundle --target aarch64-pc-windows-msvc",
    "tauri:build:mac-universal": "PATH=\"$HOME/.cargo/bin:$PATH\" tauri build --runner \"$HOME/.cargo/bin/cargo\" --target universal-apple-darwin"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-opener": "^2",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@vitejs/plugin-vue": "^5.2.1",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vue-tsc": "^2.1.10"
  }
}
